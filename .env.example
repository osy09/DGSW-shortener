# Docker 배포용 환경 변수 (.env 파일로 복사하여 사용)

# Database (Docker 내부 경로)
DATABASE_URL=file:/app/data/url.db

# App URL
NEXT_PUBLIC_BASE_URL=https://dgsw.site

# Admin Authentication (Required for /admin)
# Generate: node --input-type=module -e "import { generateSecret } from 'otplib'; console.log(generateSecret());"
TOTP_SECRET=YOUR_TOTP_SECRET_HERE

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=YOUR_JWT_SECRET_HERE

# Cloudflare Tunnel Token
CLOUDFLARE_TUNNEL_TOKEN=YOUR_CLOUDFLARE_TUNNEL_TOKEN_HERE
