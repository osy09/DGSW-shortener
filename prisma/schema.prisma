// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Link {
  id          Int    @id @default(autoincrement())
  originalUrl String
  shortCode   String @unique
  createdAt   String // 한국 시간 (YYYY-MM-DD HH:mm:ss)
  clicks      Int    @default(0)

  @@index([shortCode])
}
